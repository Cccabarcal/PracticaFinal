# Configuración de Variables de Entorno para AWS
# Copiar este archivo a .env.aws y completar con tus valores

# ===== BASE DE DATOS =====
DB_HOST=eafit-mysql-db.c9akciq32.us-east-1.rds.amazonaws.com
DB_PORT=3306
DB_USER=admin
DB_PASSWORD=EafitDB2025Secure!
DB_NAME=usuarios

# ===== APLICACIÓN =====
FLASK_ENV=production
ADMIN_PASSWORD=admin123
DEBUG=false

# ===== EMAIL SMTP =====
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu-email@gmail.com
SMTP_PASSWORD=tu-app-specific-password
EMAIL_FROM=tu-email@gmail.com

# ===== AWS =====
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=123456789012
ECR_REGISTRY=123456789012.dkr.ecr.us-east-1.amazonaws.com

# ===== CERTIFICADO SSL =====
# Obtener del AWS Certificate Manager
SSL_CERTIFICATE_ARN=arn:aws:acm:us-east-1:123456789012:certificate/xxxxx

# ===== DOMINIO =====
DOMAIN_NAME=tudominio.com
DOMAIN_CERTIFICATE=*.tudominio.com

# ===== LOGS =====
LOG_GROUP=/ecs/eafit-web-es
LOG_REGION=us-east-1
LOG_STREAM_PREFIX=ecs

# ===== CLOUDWATCH =====
ENABLE_CLOUDWATCH=true
ENABLE_XRAY_TRACING=false

# ===== PERFORMANCE =====
MAX_CONNECTIONS=100
POOL_RECYCLE=3600
GUNICORN_WORKERS=4
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=120
